{
  "name": "@stratasync/storage-idb",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync",
    "directory": "packages/storage-idb"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@stratasync/client": "*",
    "@stratasync/core": "*",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5"
  }
}
