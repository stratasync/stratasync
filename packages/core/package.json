{
  "name": "@stratasync/core",
  "version": "0.2.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "tsc --noEmit",
    "test": "node --test --import tsx \"tests/**/*.test.ts\""
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2"
  }
}
