{
  "name": "@stratasync/storage-local",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync",
    "directory": "packages/storage-local"
  },
  "files": [
    "dist"
  ],
  "type": "module",
