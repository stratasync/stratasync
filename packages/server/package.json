{
  "name": "@stratasync/server",
  "version": "0.2.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "import": "./dist/fastify/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "fastify": "^5.8.2",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "redis": "^5.11.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2",
    "vitest": "^4.1.0",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "@fastify/websocket": ">=11.0.0",
    "drizzle-orm": ">=1.0.0-beta.1",
    "fastify": ">=5.0.0",
    "redis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "@fastify/websocket": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": false
    }
  }
}
