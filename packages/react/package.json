{
  "name": "@stratasync/react",
  "version": "0.2.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@stratasync/client": "*",
    "@stratasync/core": "*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "yjs": "^13.6.0"
  }
}
