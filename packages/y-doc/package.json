{
  "name": "@stratasync/y-doc",
  "version": "0.2.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync",
    "directory": "packages/y-doc"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "check-types": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {},
  "peerDependencies": {
    "yjs": "^13.6.0"
  }
}
