{
  "name": "stratasync",
  "version": "0.0.1",
  "private": true,
  "description": "Local-first, server-sequenced sync engine for TypeScript, React, and Next.js",
  "keywords": [],
  "homepage": "https://github.com/stratasync/stratasync#readme",
  "bugs": {
    "url": "https://github.com/stratasync/stratasync/issues"
  },
  "license": "MIT",
  "author": "Matthew Blode",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratasync/stratasync"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run check-types",
    "test": "turbo run test",
    "lint": "oxfmt --check . && oxlint $(git ls-files '*.ts' '*.tsx' '*.js' '*.jsx')",
    "lint:fix": "oxfmt --write . && oxlint --fix $(git ls-files '*.ts' '*.tsx' '*.js' '*.jsx')",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "prepare": "[ -n \"$CI\" ] || lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "drizzle-orm": "1.0.0-beta.19",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "ultracite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.12.0"
}
